{
  "name": "redline",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace web & wait",
    "build": "npm run build --workspace web",
    "build:static": "npm run build:static --workspace web",
    "test": "npm run test --workspace shared && npm run test --workspace server",
    "start": "tsx server/src/index.ts"
  },
  "bin": {
    "redline": "./bin/redline.mjs"
  },
  "dependencies": {
    "tsx": "^4.19.0"
  }
}